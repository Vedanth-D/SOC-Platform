# Port scan detection
alert tcp any any -> $HOME_NET any (msg:"SCAN Port Scan Detected"; flags:S; threshold: type threshold, track by_src, count 20, seconds 10; classtype:network-scan; sid:1000001; rev:1;)

# SSH brute force
alert tcp any any -> $HOME_NET 22 (msg:"BRUTE-FORCE SSH Login Attempt"; flow:to_server,established; content:"SSH"; threshold: type threshold, track by_src, count 5, seconds 60; classtype:attempted-user; sid:1000002; rev:1;)

# SQL injection attempt
alert http any any -> $HOME_NET any (msg:"SQLI SQL Injection Attempt"; flow:to_server,established; http.uri; content:"UNION SELECT"; nocase; classtype:web-application-attack; sid:1000003; rev:1;)

# ICMP flood
alert icmp any any -> $HOME_NET any (msg:"DOS ICMP Flood Detected"; threshold: type threshold, track by_src, count 100, seconds 5; classtype:denial-of-service; sid:1000004; rev:1;)

# DNS exfiltration
alert dns any any -> any 53 (msg:"DNS Possible Data Exfiltration"; dns.query; content:"."; pcre:"/[a-z0-9]{30,}/i"; classtype:policy-violation; sid:1000005; rev:1;)

# Nmap OS detection
alert tcp any any -> $HOME_NET any (msg:"SCAN Nmap OS Detection"; flags:FPU; classtype:network-scan; sid:1000006; rev:1;)

# FTP brute force
alert tcp any any -> $HOME_NET 21 (msg:"BRUTE-FORCE FTP Login"; flow:to_server,established; content:"USER "; threshold: type threshold, track by_src, count 5, seconds 30; classtype:attempted-user; sid:1000007; rev:1;)

# Telnet insecure access
alert tcp any any -> $HOME_NET 23 (msg:"POLICY Telnet Access Detected"; flow:to_server,established; classtype:policy-violation; sid:1000008; rev:1;)

# RDP brute force
alert tcp any any -> $HOME_NET 3389 (msg:"BRUTE-FORCE RDP Login Attempt"; flow:to_server,established; threshold: type threshold, track by_src, count 5, seconds 60; classtype:attempted-user; sid:1000009; rev:1;)

# HTTP directory traversal
alert http any any -> $HOME_NET any (msg:"WEB Directory Traversal Attempt"; flow:to_server,established; http.uri; content:"../"; classtype:web-application-attack; sid:1000010; rev:1;)